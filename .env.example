# === LLM Configuration ===
GEMINI_API_KEY=your-gemini-api-key
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.7
# LLM_FAST_MODEL=gemini-2.0-flash
# LLM_POWERFUL_MODEL=gpt-4o
# LLM_PROVIDER_PRIORITY=gemini,openai,anthropic

# === Search API ===
TAVILY_API_KEY=your-tavily-api-key

# === Application ===
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# === Agent Settings ===
MAX_RETRIES=3
STEP_TIMEOUT_SECONDS=60
CLARITY_THRESHOLD=8

# === RAG Pipeline ===
CHROMA_PERSIST_DIR=./chroma_data
# CHROMA_HOST=chromadb          # Set when using Docker Compose
# CHROMA_PORT=8001
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200

# === Guardrails ===
GUARDRAILS_ENABLED=true
PII_REDACTION=true
INJECTION_DETECTION=true
MAX_INPUT_LENGTH=10000

# === Observability (OpenTelemetry) ===
TRACING_ENABLED=false
TRACING_EXPORTER=console       # "console" for dev, "otlp" for Jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# === Agent Memory ===
MEMORY_ENABLED=true
MEMORY_PERSIST_DIR=./chroma_data
MEMORY_MAX_RECALL=3
